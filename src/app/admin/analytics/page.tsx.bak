'use client';

import { useState, useEffect } from 'react';

interface VisitorAnalytics {
  totalVisitors: number;
  uniqueVisitors: number;
  returningVisitors: number;
  recentVisitors: number;
  todayVisitors: number;
  popularPages: Array<{ page: string; count: number }>;
  popularBrowsers: Array<{ browser: string; count: number }>;
  popularOS: Array<{ os: string; count: number }>;
  popularDevices: Array<{ device: string; count: number }>;
  popularCountries: Array<{ country: string; count: number }>;
}

export default function VisitorAnalytics() {
  const [analytics, setAnalytics] = useState<VisitorAnalytics | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [lastUpdate, setLastUpdate] = useState<string>('');

  // Fetch analytics data
  const fetchAnalytics = async () => {
    try {
      setIsLoading(true);
      setError(null);
      
      const response = await fetch('/api/visitor/track');
      const data = await response.json();
      
      if (data.analytics) {
        setAnalytics(data.analytics);
        setLastUpdate(new Date().toLocaleString());
      } else {
        setError('Failed to load analytics data');
      }
    } catch (err) {
      setError('Failed to fetch analytics');
    } finally {
      setIsLoading(false);
    }
  };

  // Auto-refresh every 30 seconds
  useEffect(() => {
    fetchAnalytics();
    
    const interval = setInterval(fetchAnalytics, 30000);
    
    return () => clearInterval(interval);
  }, []);

  const formatNumber = (num: number) => {
    return new Intl.NumberFormat('id-ID').format(num);
  };

  const getPercentage = (part: number, total: number) => {
    return total > 0 ? ((part / total) * 100).toFixed(1) : '0';
  };

  const getFlagEmoji = (country: string) => {
    const flags: Record<string, string> = {
      'ID': '🇮🇩',
      'US': '🇺🇸',
      'GB': '🇬🇧',
      'AU': '🇦🇺',
      'CA': '🇨🇦',
      'DE': '🇩🇪',
      'FR': '🇫🇷',
      'SG': '🇸🇬',
      'MY': '🇲🇾',
      'TH': '🇹🇭',
      'PH': '🇵🇭',
      'VN': '🇻🇳',
      'IN': '🇮🇳',
      'JP': '🇯🇵',
      'KR': '🇰🇷',
      'CN': '🇨🇳',
      'RU': '🇷🇺',
      'BR': '🇧🇷',
      'ZA': '🇿🇦',
      'MX': '🇲🇽',
      'AR': '🇸🇦',
      'SA': '🇸🇦',
      'EG': '🇪🇬',
      'NG': '🇳🇬',
      'KE': '🇰🇪',
      'TZ': '🇹🇿',
      'PK': '🇵🇰',
      'BD': '🇧🇩',
      'LK': '🇱🇰',
      'MM': '🇲🇲',
      'KH': '🇰🇭',
      'LA': '🇱🇦',
      'NP': '🇳🇵',
      'BT': '🇧🇹',
      'MN': '🇲🇲',
      'KZ': '🇰🇿',
      'KG': '🇰🇬',
      'TJ': '🇹🇯',
      'TM': '🇹🇲',
      'UZ': '🇺🇿',
      'AF': '🇦🇫',
      'DZ': '🇩🇿',
      'MA': '🇲🇲',
      'IR': '🇮🇷',
      'IQ': '🇮🇶',
      'TR': '🇹🇷',
      'YE': '🇾🇪',
      'SY': '🇸🇾',
      'JO': '🇯🇴',
      'PS': '🇵🇸',
      'LB': '🇱🇧',
      'IL': '🇮🇱',
      'KW': '🇰🇼',
      'QA': '🇶🇦',
      'BH': '🇧🇭',
      'AE': '🇦🇪',
      'OM': '🇴🇴',
      'MV': '🇲🇻',
      'CY': '🇨🇾',
      'GR': '🇬🇷',
      'IS': '🇮🇸',
      'IE': '🇮🇪',
      'IT': '🇮🇹',
      'CH': '🇨🇭',
      'DK': '🇩🇰',
      'SI': '🇸🇮',
      'NO': '🇳🇴',
      'SE': '🇸🇪',
      'FI': '🇫🇮',
      'EE': '🇪🇪',
      'LV': '🇱🇻',
      'LT': '🇱🇹',
      'EE': '🇪🇪',
      'BG': '🇧🇬',
      'RO': '🇷🇴',
      'MD': '🇲🇲',
      'RU': '🇷🇺',
      'UA': '🇺🇦',
      'BY': '🇧🇾',
      'CZ': '🇨🇿',
      'SK': '🇸🇰',
      'HU': '🇭🇺',
      'HR': '🇭🇷',
      'RS': '🇷🇸',
      'SI': '🇸🇮',
      'ME': '🇲🇪',
      'MK': '🇲🇰',
      'AL': '🇦🇱',
      'XK': '🇨🇰',
      'GE': '🇬🇪',
      'AU': '🇦🇺',
      'NZ': '🇳🇿',
      'FJ': '🇫🇯',
      'PG': '🇵🇬',
      'SB': '🇸🇧',
   'ID': '🇮🇩' // Indonesia
    };
    
    return flags[country] || '🌍';
  };

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-gray-300 border-t-blue-600"></div>
          <p className="mt-4 text-gray-600">Loading visitor analytics...</p>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="bg-red-100 border border border-red-400 text-red-700 px-4 py-3 rounded-lg">
            <p className="font-medium">Error loading analytics</p>
            <p className="text-sm">{error}</p>
          </div>
        </div>
      </div>
    );
  }

  if (!analytics) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <p className="text-gray-600">No analytics data available</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-4">
      <div className="max-w-7xl mx-auto">
        <div className="bg-white rounded-lg shadow-lg p-6">
          <div className="flex justify-between items-center mb-6">
            <h1 className="text-2xl font-bold text-gray-900">Visitor Analytics Dashboard</h1>
            <div className="flex items-center gap-4">
              <button
                onClick={fetchAnalytics}
                className="px-4 py-2 rounded-md text-sm font-medium bg-blue-600 hover:bg-blue-700 text-white transition-colors"
              >
                Refresh Data
              </button>
              <span className="text-sm text-gray-500">
                Last updated: {lastUpdate}
              </span>
            </div>
          </div>

          {/* Summary Cards */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-2">Total Visitors</h3>
              <p className="text-3xl font-bold text-blue-600">{formatNumber(analytics.totalVisitors)}</p>
              <p className="text-sm text-gray-600">All time visitors</p>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-2">Unique Visitors</h3>
              <p className="text-3xl font-bold text-green-600">{formatNumber(analytics.uniqueVisitors)}</p>
              <p className="text-sm text-gray-600">First-time visitors ({getPercentage(analytics.uniqueVisitors, analytics.totalVisitors)}%)</p>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-2">Returning Visitors</h3>
              <p className="text-3xl font-bold text-purple-600">{formatNumber(analytics.returningVisitors)}</p>
              <p className="text-sm text-gray-600">Returning visitors ({getPercentage(analytics.returningVisitors, analytics.totalVisitors)}%)</p>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-2">Recent (24h)</h3>
              <p className="text-3xl font-bold text-orange-600">{formatNumber(analytics.recentVisitors)}</p>
              <p className="text-sm text-gray-600">Visitors in last 24 hours</p>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-2">Today</h3>
              <p className="text-3xl font-bold text-teal-600">{formatNumber(analytics.todayVisitors)}</p>
              <p className="text-sm text-gray-600">Visitors today</p>
            </div>
          </div>

          {/* Popular Content */}
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-4">Popular Pages</h3>
              <div className="space-y-2">
                {analytics.popularPages.slice(0, 5).map((page, index) => (
                  <div key={index} className="flex justify-between items-center p-2 bg-gray-50 rounded">
                    <span className="text-sm font-medium text-gray-700">{page.page}</span>
                    <span className="text-lg font-bold text-blue-600">{formatNumber(page.count)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-4">Popular Browsers</h3>
              <div className="space-y-2">
                {analytics.popularBrowsers.slice(0, 5).map((browser, index) => (
                  <div key={index} className="flex justify-between items-center p-2 bg-gray-50 rounded">
                    <span className="text-sm text-gray-700">{browser.browser}</span>
                    <span className="text-lg font-bold text-blue-600">{formatNumber(browser.count)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-4">Popular Operating Systems</h3>
              <div className="space-y-2">
                {analytics.popularOS.slice(0, 5).map((os, index) => (
                  <div key={index} className="flex justify-between items-center p-2 bg-gray-50 rounded">
                    <span className="text-sm text-gray-700">{os.os}</span>
                    <span className="text-lg font-bold text-green-600">{formatNumber(os.count)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-4">Popular Devices</h3>
              <div className="space-y-2">
                {analytics.popularDevices.slice(0, 5).map((device, index) => (
                  <div key={index} className="flex justify-between items-center p-2 bg-gray-50 rounded">
                    <span className="text-sm text-gray-700">{device.device}</span>
                    <span className="text-lg font-bold text-purple-600">{formatNumber(device.count)}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className="bg-white rounded-lg border border-gray-200 p-6">
              <h3 className="text-lg font-semibold text-gray-900 mb-4">Popular Countries</h3>
              <div className="space-y-2">
                {analytics.popularCountries.slice(0, 10).map((country, index) => (
                  <div key={index} className="flex justify-between items-center p-2 bg-gray-50 rounded">
                    <span className="text-sm">
                      <span className="mr-2">{getFlagEmoji(country.country)}</span>
                      <span className="text-gray-700">{country.country}</span>
                    </span>
                    <span className="text-lg font-bold text-red-600">{formatNumber(country.count)}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Real-time Stats */}
          <div className="mt-8 p-4 bg-blue-50 rounded-lg">
            <h3 className="text-lg font-semibold text-blue-900 mb-2">Live Statistics</h3>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
              <div>
                <span className="text-gray-600">Active Session:</span>
                <span className="font-medium text-blue-600">{analytics.currentVisitor?.session || 'N/A'}</span>
              </div>
              <div>
                <span className="text-gray-600">Current Page:</span>
                <span className="font-medium text-blue-600">{analytics.currentVisitor?.page || 'N/A'}</span>
              </div>
              <div>
                <span className="text-gray-600">Browser:</span>
                <span className="font-medium text-blue-600">{analytics.currentVisitor?.browser || 'N/A'}</span>
              </div>
              <div>
                <span className="text-gray-600">Device:</span>
                <span className="font-medium text-blue-600">{analytics.currentVisitor?.device || 'N/A'}</span>
              </div>
              <div>
                <span className="text-gray-600">OS:</span>
                <span className="font-medium text-blue-600">{analytics.currentVisitor?.os || 'N/A'}</span>
              </div>
              <div>
                <span className="text-gray-600">Country:</span>
                <span className="font-medium text-blue-600">
                  {analytics.currentVisitor?.country ? `${getFlagEmoji(analytics.currentVisitor.country)} ${analytics.currentVisitor.country}` : 'N/A'}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
