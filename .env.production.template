# =============================================================================
# Palu Dev House - Production Environment Template
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Update ALL placeholder values before deployment
# 3. NEVER commit the actual .env.production file
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Next.js Environment
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://paludevhouse.site
NEXT_PUBLIC_BASE_URL=https://paludevhouse.site

# Database Configuration
DATABASE_URL=file:./data/database.sqlite

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

# ISR Revalidation Secret (MUST be changed in production!)
REVALIDATE_SECRET=your-production-revalidate-secret-key

# Admin Authentication (MUST be changed in production!)
ADMIN_PASSWORD=your-admin-password
ADMIN_USERNAME=your-admin-username

# TOTP Configuration (MUST be changed in production!)
ADMIN_TOTP_SECRET=your-production-totp-secret-key
NEXT_PUBLIC_ADMIN_TOTP_ISSUER=Palu Dev House Admin

# JWT Configuration (for future use)
JWT_SECRET=your-production-jwt-secret-key
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-production-session-secret-key

# =============================================================================
# API & INTEGRATIONS
# =============================================================================

# Discord Webhook (for build notifications)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Site Verification
# GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Yandex Verification
# YANDEX_VERIFICATION=your-yandex-verification-code

# Bing Verification
# BING_VERIFICATION=your-bing-verification-code

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Configuration for contact forms
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@paludevhouse.site
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@paludevhouse.site

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# Cloudinary (for image management)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Disable debug logging in production
DEBUG=false

# API rate limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# =============================================================================
# PERFORMANCE & CACHING
# =============================================================================

# ISR Cache Duration (in seconds)
ISR_CACHE_DURATION=3600

# Static asset optimization
NEXT_PUBLIC_IMAGE_DOMAINS=cdn.paludevhouse.site,images.paludevhouse.site

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# LogRocket (session recording)
# NEXT_PUBLIC_LOGROCKET_APP_ID=your-logrocket-app-id

# Hotjar (user analytics)
# NEXT_PUBLIC_HOTJAR_ID=your-hotjar-id

# =============================================================================
# PRODUCTION SPECIFIC
# =============================================================================

# Disable mock data in production
ENABLE_MOCK_DATA=false

# Enable ISR in production
DISABLE_ISR_IN_DEV=false

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================

# Vercel Deployment
VERCEL_URL=palu-dev-house.vercel.app

# Netlify Deployment
# NETLIFY_URL=palu-dev-house.netlify.app

# Docker Deployment
PORT=3000
HOST=0.0.0.0

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================
# [ ] Change REVALIDATE_SECRET to a cryptographically secure string
# [ ] Change ADMIN_PASSWORD to a strong password
# [ ] Change JWT_SECRET to a secure random string
# [ ] Change SESSION_SECRET to a secure random string
# [ ] Change ADMIN_TOTP_SECRET to a secure Base32 string
# [ ] Update NEXT_PUBLIC_ADMIN_TOTP_ISSUER for your organization
# [ ] Update DISCORD_WEBHOOK_URL with actual webhook
# [ ] Update NEXT_PUBLIC_GA_ID with actual tracking ID
# [ ] Update verification codes for your domain
# [ ] Configure SMTP settings for contact forms
# [ ] Configure Cloudinary for image management
# [ ] Configure Sentry for error tracking
# [ ] Test all integrations before deployment

# =============================================================================
# TOTP SETUP INSTRUCTIONS
# =============================================================================
# 1. Generate a secure Base32 secret:
#    - Use: openssl rand -base32 32
#    - Or use: python -c "import secrets, base64; print(base64.b32encode(secrets.token_bytes(20)).decode())"
# 2. Set ADMIN_TOTP_SECRET with the generated secret
# 3. Configure Google Authenticator with the secret
# 4. Test TOTP login before deployment
# 5. Store backup codes securely
