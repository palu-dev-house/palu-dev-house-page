# =============================================================================
# Palu Dev House - Environment Variables
# =============================================================================
# Copy this file to .env.local and update the values for your environment
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Next.js Environment
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://paludevhouse.site
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=file:./data/database.sqlite

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

# ISR Revalidation Secret (change this in production!)
REVALIDATE_SECRET=palu-dev-house-secret-change-in-production

# Admin Authentication
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_USERNAME=admin

# TOTP Configuration
ADMIN_TOTP_SECRET=your-totp-secret-key
NEXT_PUBLIC_ADMIN_TOTP_ISSUER=Palu Dev House Admin

# JWT Configuration (for future use)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# =============================================================================
# API & INTEGRATIONS
# =============================================================================

# Discord Webhook (optional - for build notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Site Verification
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Yandex Verification
YANDEX_VERIFICATION=your-yandex-verification-code

# Bing Verification
BING_VERIFICATION=your-bing-verification-code

# =============================================================================
# EMAIL CONFIGURATION (optional)
# =============================================================================

# SMTP Configuration for contact forms
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@paludevhouse.site

# =============================================================================
# THIRD-PARTY SERVICES (optional)
# =============================================================================

# Cloudinary (for image management)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Vercel Analytics (optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Sentry Error Tracking (optional)
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable debug logging
DEBUG=false

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# PERFORMANCE & CACHING
# =============================================================================

# ISR Cache Duration (in seconds)
ISR_CACHE_DURATION=3600

# Static asset optimization
NEXT_PUBLIC_IMAGE_DOMAINS=yourdomain.com,anotherdomain.com

# =============================================================================
# MONITORING & LOGGING (optional)
# =============================================================================

# LogRocket (optional)
NEXT_PUBLIC_LOGROCKET_APP_ID=your-logrocket-app-id

# Hotjar (optional)
NEXT_PUBLIC_HOTJAR_ID=your-hotjar-id

# =============================================================================
# LOCAL DEVELOPMENT ONLY
# =============================================================================

# Enable mock data in development
ENABLE_MOCK_DATA=true

# Disable ISR in development for faster builds
DISABLE_ISR_IN_DEV=true

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and update these for production deployment

# NODE_ENV=production
# NEXT_PUBLIC_SITE_URL=https://paludevhouse.site
# NEXT_PUBLIC_BASE_URL=https://paludevhouse.site
# DEBUG=false
# ENABLE_MOCK_DATA=false
# DISABLE_ISR_IN_DEV=false

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================

# Vercel Deployment
# VERCEL_URL=your-vercel-app-url.vercel.app

# Netlify Deployment
# NETLIFY_URL=your-netlify-app-url.netlify.app

# Docker Deployment
# PORT=3000
# HOST=0.0.0.0

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit your actual .env.local file to version control
# 2. Always use strong, unique secrets in production
# 3. Update REVALIDATE_SECRET with a cryptographically secure string
# 4. Review and update all verification codes for your domain
# 5. Test all integrations after updating environment variables
# 6. Keep your .env.example file updated with new variables
