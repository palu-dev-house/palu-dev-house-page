# =============================================================================
# Palu Dev House - Local Development Environment Template
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local for local development
# 2. Update placeholder values as needed
# 3. NEVER commit the actual .env.local file
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Next.js Environment
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=file:./data/database.sqlite

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================

# ISR Revalidation Secret (development secret)
REVALIDATE_SECRET=your-revalidate-secret-key

# Admin Authentication (development credentials)
ADMIN_PASSWORD=your-admin-password
ADMIN_USERNAME=your-admin-username

# TOTP Configuration (development secret)
ADMIN_TOTP_SECRET=your-totp-secret-key-here
NEXT_PUBLIC_ADMIN_TOTP_ISSUER=Palu Dev House Admin (Dev)

# JWT Configuration (for future use)
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-key

# =============================================================================
# API & INTEGRATIONS
# =============================================================================

# Discord Webhook (optional - for build notifications)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Analytics (disabled in development)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Site Verification (not needed in development)
# GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Yandex Verification (not needed in development)
# YANDEX_VERIFICATION=your-yandex-verification-code

# Bing Verification (not needed in development)
# BING_VERIFICATION=your-bing-verification-code

# =============================================================================
# EMAIL CONFIGURATION (optional for development)
# =============================================================================

# SMTP Configuration for contact forms
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@paludevhouse.site

# =============================================================================
# THIRD-PARTY SERVICES (optional for development)
# =============================================================================

# Cloudinary (for image management)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Vercel Analytics (disabled in development)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Sentry Error Tracking (disabled in development)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Enable debug logging in development
DEBUG=true

# API rate limiting (relaxed in development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# =============================================================================
# PERFORMANCE & CACHING
# =============================================================================

# ISR Cache Duration (shorter in development for faster updates)
ISR_CACHE_DURATION=60

# Static asset optimization
NEXT_PUBLIC_IMAGE_DOMAINS=localhost:3000

# =============================================================================
# MONITORING & LOGGING (disabled in development)
# =============================================================================

# LogRocket (disabled in development)
# NEXT_PUBLIC_LOGROCKET_APP_ID=

# Hotjar (disabled in development)
# NEXT_PUBLIC_HOTJAR_ID=

# =============================================================================
# LOCAL DEVELOPMENT SPECIFIC
# =============================================================================

# Enable mock data in development
ENABLE_MOCK_DATA=true

# Disable ISR in development for faster builds
DISABLE_ISR_IN_DEV=true

# =============================================================================
# DEVELOPMENT UTILITIES
# =============================================================================

# Enable hot reload
FAST_REFRESH=true

# Enable React strict mode
REACT_STRICT_MODE=true

# Enable TypeScript checks
TSC_COMPILE_ON_ERROR=true

# =============================================================================
# LOCAL DEVELOPMENT SETUP CHECKLIST
# =============================================================================
# [ ] Copy this file to .env.local
# [ ] Update ADMIN_PASSWORD if desired
# [ ] Update REVALIDATE_SECRET if desired
# [ ] Update ADMIN_TOTP_SECRET if desired (default provided)
# [ ] Update NEXT_PUBLIC_ADMIN_TOTP_ISSUER if desired
# [ ] Uncomment and configure Discord webhook if needed
# [ ] Uncomment and configure email settings if testing contact forms
# [ ] Uncomment and configure third-party services if testing
# [ ] Test admin login with configured credentials
# [ ] Verify ISR functionality is working
# [ ] Check that mock data is loading correctly

